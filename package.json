{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "db:geocode": "bun scripts/db-geocode.ts",
    "db:import": "bun scripts/db-import.ts",
    "db:migrate:production": "bun scripts/db-migrate-production.ts",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:up": "supabase migration up --local",
    "db:types": "supabase gen types --local --lang typescript --schema public > src/lib/database.types.ts",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@googlemaps/js-api-loader": "^2.0.2",
    "@supabase/supabase-js": "^2.98.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "csv-parse": "^6.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postgres": "^3.4.8",
    "supabase": "^2.77.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  }
}
